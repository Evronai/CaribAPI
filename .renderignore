# Ignore unnecessary files for Render builds
# This reduces build time and deployment size

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
test_venv/
venv/

# Logs
logs/
*.log

# Environment files (Render provides env vars)
.env
.env.production

# Large data files (keep samples, exclude large ones)
*.csv
!trinidad_businesses.csv  # Keep sample
*.json
!trinidad_businesses.json  # Keep sample

# Test and coverage files
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo